from openpyxl import load_workbook

#配置参数
file_path = r"C:\Users\jump\Desktop\未签字和三级联审\柳江\柳江镇两河村宅基登记核实表.xlsx"
source_sheet = "补收户籍"  #源数据表名称（和你表格底部标签一致）
target_sheet = "Sheet1"  #目标工作表名称（首字母大写，和表格一致）
check_col = 3  #检查C列（第3列）
#需要匹配的人名列表
name_list = [
    "王光贵", "康德祥", "李光会", "孔令钊", "孔令平", "江大鹏",
    "孔令兵", "李澡林", "李枝春", "孔令刚", "凌友财", "孔令君",
    "柳沈威","柳从友","孔祥东","张先华","王波","刘根华","李祇华",
    "王永平","孔令春","伍加洪","刘莉娟","罗春红","李燕伶"
]
#加载工作簿
wb = load_workbook(file_path)
#明确指定源工作表
ws_source = wb[source_sheet]
#获取或创建目标工作表
if target_sheet in wb.sheetnames:
    ws_target = wb[target_sheet]
else:
    ws_target = wb.create_sheet(target_sheet)
    #新建表时同步复制表头
    for col in range(1, ws_source.max_column + 1):
        src_cell = ws_source.cell(row=1, column=col)
        tgt_cell = ws_target.cell(row=1, column=col)
        tgt_cell.value = src_cell.value
        tgt_cell.font = src_cell.font.copy()
        tgt_cell.fill = src_cell.fill.copy()
        tgt_cell.alignment = src_cell.alignment.copy()
        tgt_cell.border = src_cell.border.copy()

#目标表下一行写入位置
next_row = ws_target.max_row + 1

#倒序遍历源表（从最后一行到第2行，跳过表头）
for row in range(ws_source.max_row, 1, -1):
    cell_value = ws_source.cell(row=row, column=check_col).value
    # 空值容错：单元格为空时跳过，避免转字符串后出现"None"
    if cell_value is None:
        continue
    cell_val = str(cell_value)

    #判断是否包含任意目标人名
    if any(name in cell_val for name in name_list):
        #复制整行数据+样式到目标表
        for col in range(1, ws_source.max_column + 1):
            src_cell = ws_source.cell(row=row, column=col)
            tgt_cell = ws_target.cell(row=next_row, column=col)
            tgt_cell.value = src_cell.value
            tgt_cell.font = src_cell.font.copy()
            tgt_cell.fill = src_cell.fill.copy()
            tgt_cell.alignment = src_cell.alignment.copy()
            tgt_cell.border = src_cell.border.copy()
        next_row += 1
        #删除源表对应行
        ws_source.delete_rows(row)

#保存文件
wb.save(file_path)
wb.close()
print(f"处理完成：共移动 {next_row - 2} 条匹配数据到Sheet1，原表对应行已删除")
